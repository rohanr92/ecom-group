// Save as: prisma/schema.prisma (REPLACE ENTIRE FILE)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum PaymentMethod {
  STRIPE
  SQUARE
  PAYPAL
  FREE
}

enum PromoType {
  PERCENT
  FIXED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String?  @map("password_hash")
  role         Role     @default(CUSTOMER)
  emailOptIn   Boolean  @default(true) @map("email_opt_in")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders         Order[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  sessions       UserSession[]
  userAddresses  UserAddress[]
  returnRequests ReturnRequest[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String   @default("Home")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  street    String
  street2   String?
  city      String
  state     String
  zip       String
  country   String   @default("United States")
  phone     String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  details      String[]
  price        Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @map("compare_price") @db.Decimal(10, 2)
  category     String
  badge        String?
  images       String[]
  isActive     Boolean  @default(true) @map("is_active")
  isGrouped    Boolean  @default(true) @map("is_grouped")
  tags         String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  variants      ProductVariant[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  collections   CollectionProduct[]

  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  size      String
  color     String
  colorHex  String   @map("color_hex")
  sku       String   @unique
  upc       String?
  inventory Int      @default(0)
  images    String[] @default([])

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems           OrderItem[]
  wishlistItems        WishlistItem[]
  miraklInventoryState MiraklInventoryState?

  @@map("product_variants")
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique @map("order_number")
  userId          String?       @map("user_id")
  email           String
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @map("shipping_cost") @db.Decimal(10, 2)
  tax             Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  stripePaymentId String?       @map("stripe_payment_id")
  paypalOrderId   String?       @map("paypal_order_id")
  shippoOrderId   String?       @map("shippo_order_id")
  trackingNumber  String?       @map("tracking_number")
  trackingUrl     String?       @map("tracking_url")
  courier         String?       @map("courier")
  promoCode       String?       @map("promo_code")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user           User?           @relation(fields: [userId], references: [id])
  items          OrderItem[]
  addresses      Address[]
  returnRequests ReturnRequest[]

  miraklOrderId  String?   @unique @map("mirakl_order_id")
  miraklChannel  String?   @map("mirakl_channel")
  miraklStatus   String?   @map("mirakl_status")
  packingSlipUrl String?   @map("packing_slip_url")
  miraklSyncedAt DateTime? @map("mirakl_synced_at")
  miraklRawData  Json?     @map("mirakl_raw_data")

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  variantId String  @map("variant_id")
  name      String
  size      String
  color     String
  image     String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Address {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  type      AddressType @default(SHIPPING)
  firstName String      @map("first_name")
  lastName  String      @map("last_name")
  street    String
  street2   String?
  city      String
  state     String
  zip       String
  country   String      @default("United States")
  phone     String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model ReturnRequest {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  orderId      String   @map("order_id")
  orderNumber  String   @map("order_number")
  email        String
  reason       String
  details      String?
  items        Json
  status       String   @default("PENDING")
  refundAmount Decimal? @map("refund_amount") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User? @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@map("return_requests")
}

model Review {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  userId    String?  @map("user_id")
  name      String
  rating    Int
  title     String
  body      String
  size      String?
  bodyType  String?  @map("body_type")
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  helpful   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model PromoCode {
  id        String    @id @default(uuid())
  code      String    @unique
  type      PromoType @default(PERCENT)
  value     Decimal   @db.Decimal(10, 2)
  minOrder  Decimal?  @map("min_order") @db.Decimal(10, 2)
  usesLeft  Int?      @map("uses_left")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("promo_codes")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  variantId String?  @map("variant_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model AdminUser {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("editor")
  permissions  String[]
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  invitedBy    String?   @map("invited_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

model Collection {
  id          String              @id @default(uuid())
  name        String
  slug        String              @unique
  description String?
  image       String?
  isActive    Boolean             @default(true) @map("is_active")
  sortOrder   Int                 @default(0) @map("sort_order")
  products    CollectionProduct[]
  slots       CollectionSlot[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("collections")
}

model CollectionProduct {
  id           String     @id @default(uuid())
  collectionId String     @map("collection_id")
  productId    String     @map("product_id")
  sortOrder    Int        @default(0) @map("sort_order")
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([collectionId, productId])
  @@map("collection_products")
}

model CollectionSlot {
  id           String      @id @default(uuid())
  slot         String      @unique
  label        String
  collectionId String?     @map("collection_id")
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("collection_slots")
}

model CmsPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  sections  Json
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("cms_pages")
}

model CmsSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_settings")
}

model NavItem {
  id        String   @id @default(uuid())
  label     String
  href      String?
  tab       String   @default("women")
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  isSale    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  sections NavSection[]
  featured NavFeatured?

  @@map("nav_items")
}

model NavSection {
  id        String @id @default(uuid())
  navItemId String @map("nav_item_id")
  heading   String
  position  Int    @default(0)

  navItem NavItem   @relation(fields: [navItemId], references: [id], onDelete: Cascade)
  links   NavLink[]

  @@map("nav_sections")
}

model NavLink {
  id        String @id @default(uuid())
  sectionId String @map("section_id")
  label     String
  href      String
  position  Int    @default(0)

  section NavSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("nav_links")
}

model NavFeatured {
  id        String @id @default(uuid())
  navItemId String @unique @map("nav_item_id")
  image     String
  label     String
  href      String

  navItem NavItem @relation(fields: [navItemId], references: [id], onDelete: Cascade)

  @@map("nav_featured")
}

model AdminSession {
  id        String   @id @default(uuid())
  token     String   @unique
  adminId   String?  @map("admin_id")
  role      String   @default("editor")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_sessions")
}

model FooterColumn {
  id        String       @id @default(uuid())
  heading   String
  position  Int          @default(0)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  links     FooterLink[]

  @@map("footer_columns")
}

model FooterLink {
  id             String       @id @default(uuid())
  label          String
  href           String       @default("#")
  position       Int          @default(0)
  isActive       Boolean      @default(true) @map("is_active")
  openInNewTab   Boolean      @default(false) @map("open_in_new_tab")
  footerColumnId String       @map("footer_column_id")
  column         FooterColumn @relation(fields: [footerColumnId], references: [id], onDelete: Cascade)

  @@map("footer_links")
}

model FooterSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("footer_settings")
}

model InfluencerApplication {
  id            String   @id @default(uuid())
  name          String
  email         String
  handle        String
  followerCount String   @map("follower_count")
  message       String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("influencer_applications")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  source    String   @default("footer")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model MiraklSyncLog {
  id             String    @id @default(uuid())
  syncType       String    @map("sync_type")
  status         String
  itemsProcessed Int       @default(0) @map("items_processed")
  itemsSucceeded Int       @default(0) @map("items_succeeded")
  itemsFailed    Int       @default(0) @map("items_failed")
  durationMs     Int?      @map("duration_ms")
  errorMessage   String?   @map("error_message")
  details        Json?
  wasDryRun      Boolean   @default(false) @map("was_dry_run")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  alertSent  Boolean  @default(false) @map("alert_sent")

  @@index([startedAt(sort: Desc)])
  @@index([syncType])
  @@map("mirakl_sync_logs")
}

model MiraklInventoryState {
  variantId           String    @id @map("variant_id")
  lastPushedInventory Int?      @map("last_pushed_inventory")
  lastPushedPrice     Decimal?  @map("last_pushed_price") @db.Decimal(10, 2)
  lastSyncedAt        DateTime? @map("last_synced_at")
  lastError           String?   @map("last_error")
  isSynced            Boolean   @default(false) @map("is_synced")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("mirakl_inventory_state")
}
